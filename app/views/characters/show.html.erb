<h1><%= @character.name %></h1>

<% if @character.image_url.present? %>
  <%= image_tag @character.image_url, width: 200 %>
<% end %>

<% if @character.real_name.present? %>
  <p>Real Name: <%= @character.real_name %></p>
<% end %>

<% if @character.deck.present? %>
  <p><%= @character.deck %></p>
<% end %>

<% if @character.publisher.present? %>
  <p>Publisher: <%= link_to @character.publisher.name, publisher_path(@character.publisher) %></p>
<% end %>

<h2>Appearances</h2>
<% if @character.issues.any? %>
  <ul>
    <% @character.issues.each do |issue| %>
      <li><%= link_to issue.name.present? ? issue.name : "Issue ##{issue.issue_number}", issue_path(issue) %></li>
    <% end %>
  </ul>
<% else %>
  <p>No issues found for this character.</p>
<% end %>

<%= link_to "Back to Characters", characters_path %>